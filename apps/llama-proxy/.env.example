# llama-proxy environment configuration
# Copy this file to .env and fill in your values.
# The proxy reads these at startup via python-dotenv (install: pip install python-dotenv)
# or export them in your shell before running uvicorn.

# Base URL of the running llama.cpp server (default: http://localhost:8080)
LLAMA_CPP_URL=http://localhost:8080

# Which backend profile to activate on startup (default: gemma4-obliterated)
# Must match an "id" in AVAILABLE_BACKENDS or the built-in defaults.
ACTIVE_BACKEND_ID=gemma4-obliterated

# HuggingFace token — required if the model repo is gated/private.
# llama-server -hf reads this via --hf-token; scripts/start-llm.sh passes it automatically.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the full backend list as a JSON array.
# Each entry must have: id, name, url, model, temperature, top_p, top_k, repeat_penalty
# Leave unset to use the two built-in Gemma-4 profiles.
#
# AVAILABLE_BACKENDS=[
#   {
#     "id": "gemma4-obliterated",
#     "name": "Gemma 4 Obliterated (Q8_0)",
#     "url": "http://localhost:8080",
#     "model": "local-model",
#     "temperature": 0.7,
#     "top_p": 0.9,
#     "top_k": 40,
#     "repeat_penalty": 1.1
#   },
#   {
#     "id": "gemma4-uncensored",
#     "name": "Gemma 4 Uncensored (Q6_K_P)",
#     "url": "http://localhost:8080",
#     "model": "local-model",
#     "temperature": 0.8,
#     "top_p": 0.95,
#     "top_k": 50,
#     "repeat_penalty": 1.0
#   }
# ]

